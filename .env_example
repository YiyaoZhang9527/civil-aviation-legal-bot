# ── Ollama（本地部署）────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_THINKING=false

# ── OpenAI ─────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODELS=gpt-4o,gpt-4-turbo,gpt-4,o3-mini
OPENAI_THINKING=false

# ── Anthropic Claude ──────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODELS=claude-sonnet-4-20250514,claude-haiku-4-5-20251001,claude-opus-4-20250514

# ── DeepSeek ──────────────────────────────────────────────────
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODELS=deepseek-v4-flash,deepseek-v4-pro
DEEPSEEK_THINKING=true

# ── 自定义提供商（OpenAI 兼容接口，支持无限扩展）─────────────
# 格式：CUSTOM_API_{字段}_{序号}，序号从 1 开始递增
# 字段：NAME / KEY / BASE_URL / MODELS / THINKING

# 硅基流动 SiliconFlow
CUSTOM_API_NAME_1=硅基流动
CUSTOM_API_KEY_1=your-siliconflow-api-key
CUSTOM_API_BASE_URL_1=https://api.siliconflow.cn/v1
CUSTOM_API_MODELS_1=deepseek-ai/DeepSeek-V3,Qwen/Qwen2.5-72B-Instruct
CUSTOM_API_THINKING_1=false

# 通义千问
CUSTOM_API_NAME_2=通义千问
CUSTOM_API_KEY_2=your-dashscope-api-key
CUSTOM_API_BASE_URL_2=https://dashscope.aliyuncs.com/compatible-mode/v1
CUSTOM_API_MODELS_2=qwen-max,qwen-plus,qwen-turbo
CUSTOM_API_THINKING_2=false

# 月之暗面 Moonshot/Kimi
CUSTOM_API_NAME_3=Moonshot
CUSTOM_API_KEY_3=your-moonshot-api-key
CUSTOM_API_BASE_URL_3=https://api.moonshot.cn/v1
CUSTOM_API_MODELS_3=moonshot-v1-128k,moonshot-v1-32k,moonshot-v1-8k
CUSTOM_API_THINKING_3=false

# 智谱 GLM
CUSTOM_API_NAME_4=智谱GLM
CUSTOM_API_KEY_4=your-zhipu-api-key
CUSTOM_API_BASE_URL_4=https://open.bigmodel.cn/api/paas/v4
CUSTOM_API_MODELS_4=glm-4-plus,glm-4-flash
CUSTOM_API_THINKING_4=false

# 百度文心
CUSTOM_API_NAME_5=文心一言
CUSTOM_API_KEY_5=your-wenxin-api-key
CUSTOM_API_BASE_URL_5=https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop
CUSTOM_API_MODELS_5=ernie-4.0-8k,ernie-3.5-8k
CUSTOM_API_THINKING_5=false
